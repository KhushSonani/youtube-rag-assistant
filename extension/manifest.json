{
  "manifest_version": 3,
  "name": "YouTube RAG Assistant",
  "version": "1.0.0",
  "description": "Ask questions about any YouTube video using AI — powered by LangChain + Groq.",

  "permissions": ["tabs", "activeTab"],

  "host_permissions": [
    "http://localhost:8000/*",
    "https://www.youtube.com/*",
    "https://youtu.be/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "YouTube RAG Assistant"
  },

  "background": {
    "service_worker": "background.js"
  }
}
